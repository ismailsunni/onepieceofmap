{
  "name": "onepieceofmap",
  "version": "2.0.0",
  "description": "A map showing real-world locations that inspired One Piece",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "csv-to-geojson": "node scripts/csv-to-geojson.mjs",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{js,css}' '*.html'",
    "format:check": "prettier --check 'src/**/*.{js,css}' '*.html'"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "vite": "^6.3.1"
  }
}
